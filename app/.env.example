# Copy to .env.local — any value left unset falls back to demo mode.

# Where Submit should POST the JSON payload (e.g. webhook.site URL or Zapier hook)
VITE_SUBMIT_WEBHOOK_URL=

# Calendly embed URL for the "Schedule a call" CTA
VITE_CALENDLY_URL=

# Set to "false" to disable the Pathfinder flow (Landing + AI chat)
VITE_PATHFINDER_ENABLED=true

# Access key required to view /admin (append ?k=<key>)
VITE_ADMIN_KEY=
